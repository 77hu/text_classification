<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>三国游戏数据实时展示</title>
    {% load static %}
    <link rel="stylesheet" href="{% static 'tower/style.css' %}">
</head>
<body>
    <div class="container">
        <h1>三国游戏数据实时展示</h1>

        <div class="status {% if status == 'connected' %}connected{% else %}disconnected{% endif %}" id="connection-status">
            {% if status == 'connected' %}已连接到服务器，实时接收数据中...{% else %}正在连接服务器...{% endif %}
        </div>

        <div class="countdown" id="countdown">
            <div class="countdown-text">距离下一次攻击还有</div>
            <div id="countdown-timer" class="countdown-timer">{{ countdown }}</div>
        </div>

        <div class="stats-container">
            <div class="stats-title">最近100次进攻城池占比</div>
            <div id="stats-grid" class="stats-grid">
                {% for s in stats %}
                <div class="stats-item">
                    <span class="stats-name">{{ s.name }}</span>
                    <span class="stats-percent">{{ s.percent }}%</span>
                    <span class="stats-count">({{ s.count }})</span>
                </div>
                {% empty %}
                <div class="no-data">暂无统计数据</div>
                {% endfor %}
            </div>
        </div>

        <div class="tower-list" id="tower-container">
            {% if records %}
                {% for r in records %}
                <div class="tower-row">
                    <div class="tower-number">{{ forloop.counter }}</div>
                    <div class="tower-icon">
                        <img src="{{ r.tower_icon }}" alt="{{ r.tower_name }}" onerror="this.src='https://via.placeholder.com/60x45?text={{ r.tower_name }}'">
                    </div>
                    <div class="tower-info">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <div class="tower-name">敌军进攻：{{ r.tower_name }}</div>
                            {% if r.tower_rate %}
                            <div class="tower-rate">倍率：<span>{{ r.tower_rate }}</span></div>
                            {% endif %}
                        </div>
                        <div class="tower-time">{{ r.time }}</div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="no-data">正在加载数据...</div>
            {% endif %}
        </div>
    </div>

    <div id="attack-alert" class="attack-alert">敌军正在进攻！</div>

    <script>
        const COUNTDOWN_INTERVAL = 59;
        let countdownValue = 0;

        function updateCountdownDisplay() {
            const el = document.getElementById('countdown-timer');
            if (countdownValue <= 0) {
                el.textContent = '即将开始';
                return;
            }
            const m = Math.floor(countdownValue / 60);
            const s = countdownValue % 60;
            el.textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
            if (countdownValue <= 10) {
                el.classList.add('alert');
            } else {
                el.classList.remove('alert');
            }
        }

        function renderRecords(records) {
            const container = document.getElementById('tower-container');
            if (!records || records.length === 0) {
                container.innerHTML = '<div class="no-data">暂无数据</div>';
                return;
            }
            container.innerHTML = records.map(function(r, i) {
                return '<div class="tower-row">' +
                    '<div class="tower-number">' + (i + 1) + '</div>' +
                    '<div class="tower-icon"><img src="' + r.tower_icon + '" alt="' + r.tower_name + '" onerror="this.src=\'https://via.placeholder.com/60x45?text=' + r.tower_name + '\'"></div>' +
                    '<div class="tower-info">' +
                    '<div class="tower-details">' +
                    '<div class="tower-name">敌军进攻：' + r.tower_name + '</div>' +
                    (r.tower_rate ? '<div class="tower-rate"> 倍率：<span>' + r.tower_rate + '</span></div>' : '') +
                    '</div>' +
                    '<div class="tower-time">' + r.time + '</div>' +
                    '</div></div>';
            }).join('');
        }

        function renderStats(stats) {
            const grid = document.getElementById('stats-grid');
            if (!stats || stats.length === 0) {
                grid.innerHTML = '<div class="no-data">暂无统计数据</div>';
                return;
            }
            grid.innerHTML = stats.map(function(s) {
                return '<div class="stats-item">' +
                    '<span class="stats-name">' + s.name + '</span>' +
                    '<span class="stats-percent">' + s.percent + '%</span>' +
                    '<span class="stats-count">(' + s.count + ')</span>' +
                    '</div>';
            }).join('');
        }

        function showAttackAlert(towerName) {
            const el = document.getElementById('attack-alert');
            el.textContent = towerName ? '敌军正在进攻' + towerName + '！' : '敌军正在进攻！';
            el.classList.add('show');
            document.getElementById('countdown-timer').classList.add('alert');
            setTimeout(function() {
                el.classList.remove('show');
            }, 5000);
        }

        function fetchData() {
            fetch('/api/data/')
                .then(function(resp) { return resp.json(); })
                .then(function(data) {
                    var statusEl = document.getElementById('connection-status');
                    if (data.status === 'connected') {
                        statusEl.className = 'status connected';
                        statusEl.textContent = '已连接到服务器，实时接收数据中...';
                    } else {
                        statusEl.className = 'status disconnected';
                        statusEl.textContent = '正在连接服务器...';
                    }

                    renderRecords(data.records);
                    renderStats(data.stats);

                    if (data.countdown !== '{{ countdown }}') {
                        countdownValue = parseCountdown(data.countdown);
                    }
                })
                .catch(function() {
                    var statusEl = document.getElementById('connection-status');
                    statusEl.className = 'status disconnected';
                    statusEl.textContent = '与服务器断开连接...';
                });
        }

        function parseCountdown(str) {
            if (str === '即将开始' || str === '--:--') return 0;
            var parts = str.split(':');
            return parseInt(parts[0]) * 60 + parseInt(parts[1]);
        }

        updateCountdownDisplay();
        setInterval(function() {
            if (countdownValue > 0) {
                countdownValue--;
                updateCountdownDisplay();
            }
        }, 1000);
        fetchData();
        setInterval(fetchData, 3000);
    </script>
</body>
</html>
